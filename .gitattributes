# Keep vendored research/runtime code from dominating GitHub language stats.
gait_runtime/mmseg/** linguist-vendored
gait_runtime/paddle/paddleseg/** linguist-vendored
gait_runtime/ultralytics/** linguist-vendored

# Required runtime checkpoints (Git LFS — clone with `git lfs pull`).
checkpoints/**/*.pt filter=lfs diff=lfs merge=lfs -text
checkpoints/**/*.pth filter=lfs diff=lfs merge=lfs -text
checkpoints/**/*.pdmodel filter=lfs diff=lfs merge=lfs -text
checkpoints/**/*.pdiparams filter=lfs diff=lfs merge=lfs -text

# Treat other generated media as binary artifacts.
*.onnx binary
*.pkl binary
*.mp4 binary
*.avi binary
*.mov binary
*.mkv binary
*.png binary
*.jpg binary
*.jpeg binary

# Exclude local-only material from source archives.
output/ export-ignore
